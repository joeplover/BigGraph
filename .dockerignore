# Git / 版本相关
.git/
.gitignore

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# 环境变量（敏感信息）
.env

# 本地文档
*.md

# 日志
logs/

# IDE
.idea/
.vscode/

# Windows 脚本（Docker 用不到）
*.bat
*.ps1

# Python 打包
__pypackages__/
*.egg-info/
dist/
build/

# 前端 node_modules（由 Docker 构建阶段处理）
frontend/node_modules/

# 本地 Python 虚拟环境
biggraph_env/
venv/
.venv/

# 运行时上传目录（由 volume 管理）
uploads/

# 临时文件
*.tmp
*.swp
*.swo